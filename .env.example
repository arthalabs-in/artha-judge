# Local demo storage
STORAGE_BACKEND=sqlite
SQLITE_DB_PATH=user_data/local_demo/artha.db
JUDGMENT_DATA_ROOT=user_data/judgments

# Local demo mode
JUDGMENT_SYNC_PROCESSING=1
JUDGMENT_DEMO_AUTH_BYPASS=1
DISABLE_RAG_STARTUP=1
CANVAS_APP_ID=theme11-local
APP_SESSION_SECRET=change-me
PROGRESS_HMAC_SECRET=change-me

# Optional LLM path
ACTIVE_LLM_PROVIDER=groq
GROQ_MODEL_NAME=openai/gpt-oss-120b
GROQ_API_KEY=replace-with-your-groq-key

# LLM observability/cache flags
ENABLE_LLM_TIMING_SPLIT=true
ENABLE_LLM_RAW_CACHE=false
ENABLE_LLM_SINGLEFLIGHT=false
ENABLE_LLM_KEEPALIVE_SESSION=true
